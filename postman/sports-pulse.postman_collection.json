        {
          "name": "get fixtures with not allowed date returns external error",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const fechaActual = new Date();",
                  "const fechaFutura = new Date(fechaActual);",
                  "fechaFutura.setDate(fechaActual.getDate() + 7);",
                  "",
                  "const año = String(fechaFutura.getFullYear()).padStart(2, '0'); ",
                  "const mes = String(fechaFutura.getMonth() + 1).padStart(2, '0'); ",
                  "    ",
                  "const dia = String(fechaFutura.getDate()).padStart(2, '0'); ",
                  "",
                  "const fechaFinal = `${año}-${mes}-${dia}`;",
                  "",
                  "pm.variables.set('NEXT_WEEK_DATE', fechaFinal);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => {",
                  "    pm.response.to.have.status(400);",
                  "})",
                  "",
                  "pm.test('Returns the error response', () => {",
                  "    pm.response.to.be.json;",
                  "    pm.expect(pm.response.json()).to.be.an('object');",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.code).to.equal('EXTERNAL_API_ERROR');",
                  "    pm.expect(body.errors).to.haveOwnProperty('plan')",
                  "    pm.expect(body.errors.plan).to.include('Free plans do not have access to this date');",
                  "",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{FIXTURES_BASE_URL}}/api/fixtures?date={{NEXT_WEEK_DATE}}",
              "host": [
                "{{FIXTURES_BASE_URL}}"
              ],
              "path": [
