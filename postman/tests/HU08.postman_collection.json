{
  "info": {
    "_postman_id": "9b40ea9f-3397-40c1-9d49-8ce82ca91ef5",
    "name": "HU08",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52397136"
  },
  "item": [
    {
      "name": "setup",
      "item": [
        {
          "name": "Register ok",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => {",
                  "    pm.response.to.have.status(201)",
                  "})",
                  "",
                  "pm.test('Body should be valid JSON', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('object')",
                  "});",
                  "",
                  "pm.test('Response body contains id', () => {",
                  "    pm.expect(pm.response.json().id).to.not.be.null",
                  "",
                  "    pm.environment.set(\"USER_ID\", pm.response.json().id)",
                  "    pm.environment.set(\"USER_EMAIL\", pm.response.json().email)",
                  "    pm.environment.set(\"USER_USERNAME\", pm.response.json().username)",
                  "",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{$randomUUID}}\",\n    \"email\": \"{{$randomUUID}}@email.com\",\n    \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{AUTH_BASE_URL}}/api/auth/register",
              "host": [
                "{{AUTH_BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Login OK",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "    pm.response.to.have.status(200)",
              "})",
              "",
              "pm.test('Token and info is returned', () => {",
              "    const data = pm.response.json()",
              "    pm.expect(data.token).to.not.be.null",
              "    pm.expect(data.tokenType).to.be.eq('Bearer')",
              "    pm.expect(data.expiresIn).to.be.above(0)",
              "    pm.expect(data.userId).to.not.be.null",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{USER_EMAIL}}\",\n    \"password\": \"Password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{AUTH_BASE_URL}}/api/auth/login",
          "host": [
            "{{AUTH_BASE_URL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Wrong credentials",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401', () => {",
              "    pm.response.to.have.status(401)",
              "})",
              "",
              "pm.test('Token and info is returned', () => {",
              "    const data = pm.response.json()",
              "    pm.expect(data.error).to.be.eq('INVALID_CREDENTIALS')",
              "    pm.expect(data.message).to.be.eq('Email o contraseña incorrectos')",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"a@email.com\",\n    \"password\": \"Password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{AUTH_BASE_URL}}/api/auth/login",
          "host": [
            "{{AUTH_BASE_URL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    }
  ]
}