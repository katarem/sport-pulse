    {
      "name": "subscription to team webhook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => {",
              "    pm.response.to.have.status(201)",
              "})",
              "",
              "pm.test('Response body contains expected data', () => {",
              "    const data = pm.response.json()",
              "    pm.expect(data.userId, \"userId should be a string\").to.be.a('string');",
              "    pm.expect(data.userId, \"userId should be the one who did the request\").to.be.eq(pm.environment.get('USER_1_ID'));",
              "    pm.expect(data.teamId, \"teamId should be a number\").to.be.a('number');",
              "    pm.expect(data.teamId, \"teamId should be the one we sent in the request\").to.be.eq(Number.parseInt(pm.environment.get('TEAM_ID')));",
              "    pm.expect(data.type, \"type should be a string\").to.be.a('string');",
              "    pm.expect(data.type, \"type should be 'TEAM'\").to.be.eq('TEAM');",
              "    pm.expect(data.createdAt, \"createdAt should be a string\").to.be.a('string');",
              "    pm.expect(data.channel, \"channel should be string\").to.be.a('string');",
              "    pm.expect(data.channel, \"channel should be 'WEBHOOK'\").to.be.eq('WEBHOOK');",
              "    pm.expect(data.status, \"status should be a string\").to.be.a('string');",
              "    pm.expect(data.status, \"status should be 'ACTIVE'\").to.be.eq('ACTIVE');",
              "    pm.expect(data.subscriptionId, \"subscriptionId should be returned\").to.be.a('string');",
              "    pm.expect(data.events, 'events should be an array of strings').to.be.an('array');",
              "    pm.expect(data.events, 'events should include all the sent parameters').to.include.all.members(['MATCH_START', 'GOAL', 'MATCH_END', 'CARD']);",
              "",
              "    pm.environment.set('NOTIFICATION_ID', data.subscriptionId);",
              "",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{USER_1_TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"teamId\": {{TEAM_ID}},\n    \"type\": \"TEAM\",\n    \"events\": [\"MATCH_START\", \"MATCH_END\", \"GOAL\", \"CARD\"],\n    \"webhookUrl\": \"https://my.telegrambot.com/webhook\",\n    \"channel\": \"WEBHOOK\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{NOTIFICATIONS_BASE_URL}}/api/notifications/subscribe",
          "host": [
            "{{NOTIFICATIONS_BASE_URL}}"
          ],
          "path": [
            "api",
            "notifications",
            "subscribe"
          ]
        }
      },
      "response": []
    },
