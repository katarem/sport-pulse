  "item": [
    {
      "name": "Register ok",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => {",
              "    pm.response.to.have.status(201)",
              "})",
              "",
              "pm.test('Body should be valid JSON', () => {",
              "    pm.expect(pm.response.json()).to.be.an('object')",
              "});",
              "",
              "pm.test('Response body contains id', () => {",
              "    pm.expect(pm.response.json().id).to.not.be.null",
              "",
              "    pm.environment.set(\"USER_ID\", pm.response.json().id)",
              "    pm.environment.set(\"USER_EMAIL\", pm.response.json().email)",
              "    pm.environment.set(\"USER_USERNAME\", pm.response.json().username)",
              "",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"{{$randomUUID}}\",\n    \"email\": \"{{$randomUUID}}@email.com\",\n    \"password\": \"Password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{AUTH_BASE_URL}}/api/auth/register",
          "host": [
            "{{AUTH_BASE_URL}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Conflict username",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is conflict', () => {",
              "    pm.response.to.have.status(409)",
              "})",
              "",
              "pm.test('Error is USER_ALREADY_EXISTS', () => {",
              "    ",
              "    const data = pm.response.json()",
              "    pm.expect(data.error).to.eql('USER_ALREADY_EXISTS')",
              "    pm.expect(data.message).to.include('Ya existe un usuario con ese username')",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
