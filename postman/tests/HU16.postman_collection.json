  "item": [
    {
      "name": "Get Events returns ok",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should return 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Should return an array', () => {",
              "    pm.response.to.be.json;",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('array');",
              "});",
              "",
              "pm.test('If not empty, should have the keys', () => {",
              "    ",
              "    const data = pm.response.json();",
              "",
              "    for (event of data) {",
              "",
              "        pm.expect(event).to.have.all.keys('elapsed', 'type', 'detail', 'team', 'player', 'assist');",
              "        pm.expect(event.team).to.have.all.keys('id', 'name');",
              "        pm.expect(event.player).to.have.all.keys('id', 'name');",
              "        ",
              "",
              "        pm.expect(event.elapsed, 'Elapsed debe ser un número').to.be.a('number');",
              "        pm.expect(event.type, 'Type debe ser un string').to.be.a('string');",
              "        pm.expect(event.detail, 'Detail debe ser un string').to.be.a('string');",
              "        pm.expect(event.team.id, 'Team ID debe ser un número').to.be.a('number');",
              "        pm.expect(event.team.name, 'Team name debe ser un string').to.be.a('string');",
              "        pm.expect(event.player.id, 'Player ID debe ser un número').to.be.a('number');",
              "        pm.expect(event.player.name, 'Player name debe ser un string').to.be.a('string');",
              "",
              "        if (event.assist !== null) {",
              "            pm.expect(event.assist).to.have.all.keys('id', 'name');",
              "            pm.expect(event.assist.id, 'Assist ID debe ser un número').to.be.a('number');",
              "            pm.expect(event.assist.name, 'Assist name debe ser un string').to.be.a('string');",
              "        }",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{FIXTURES_BASE_URL}}/api/fixtures/:fixtureId/events",
          "host": [
            "{{FIXTURES_BASE_URL}}"
          ],
          "path": [
            "api",
            "fixtures",
            ":fixtureId",
            "events"
          ],
          "variable": [
            {
              "key": "fixtureId",
              "value": "{{FIXTURE_ID}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Events Invalid ID returns error",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should return 400', () => {",
              "    pm.response.to.have.status(400)",
              "});",
              "",
              "pm.test('Should return an error', () => {",
              "    pm.response.to.be.json;",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('object');",
              "});",
              "",
              "pm.test('Error should be with keys', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.have.property('code');",
              "    pm.expect(data).to.have.property('errors');",
              "    pm.expect(data).to.have.property('timestamp');",
              "",
              "    pm.expect(data.code).to.equal('EXTERNAL_API_ERROR');",
              "    pm.expect(data.errors).to.have.key('fixture');",
              "    pm.expect(data.errors.fixture).to.be.eq('The Fixture field cannot exceed 10 characters in length.')",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{FIXTURES_BASE_URL}}/api/fixtures/:fixtureId/events",
          "host": [
            "{{FIXTURES_BASE_URL}}"
          ],
          "path": [
            "api",
            "fixtures",
            ":fixtureId",
            "events"
          ],
          "variable": [
            {
              "key": "fixtureId",
              "value": "10000000000"
            }
          ]
        }
      },
      "response": []
    }
  ]
}