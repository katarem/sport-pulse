        {
          "name": "Register user 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => {",
                  "    pm.response.to.have.status(201)",
                  "})",
                  "",
                  "pm.test('Body should be valid JSON', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('object')",
                  "});",
                  "",
                  "pm.test('Response body contains id', () => {",
                  "    pm.expect(pm.response.json().id).to.not.be.null",
                  "",
                  "    pm.environment.set(\"USER_1_ID\", pm.response.json().id)",
                  "    pm.environment.set(\"USER_1_EMAIL\", pm.response.json().email)",
                  "    pm.environment.set(\"USER_1_USERNAME\", pm.response.json().username)",
                  "",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{$randomUUID}}\",\n    \"email\": \"{{$randomUUID}}@email.com\",\n    \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{GATEWAY_BASE_URL}}/api/auth/register",
              "host": [
                "{{GATEWAY_BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
