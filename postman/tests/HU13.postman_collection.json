              "});\r",
              "pm.test(\"Error response structure\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('object');\r",
              "    pm.expect(json).to.have.property('code');\r",
              "    pm.expect(json).to.have.property('errors');\r",
              "    pm.expect(json).to.have.property('timestamp');\r",
              "});\r",
              "pm.test(\"Message content is correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.code).to.eql(\"TEAM_NOT_FOUND\");\r",
              "    pm.expect(json.errors).to.have.property('teamId');\r",
              "    pm.expect(json.errors.teamId).to.include(\"No existe un equipo con el ID proporcionado\");\r",
              "});"
            ],
