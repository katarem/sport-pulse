          "name": "Login OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test('Token and info is returned', () => {",
                  "    const data = pm.response.json()",
                  "    pm.expect(data.token).to.not.be.null",
                  "    pm.expect(data.tokenType).to.be.eq('Bearer')",
                  "    pm.expect(data.expiresIn).to.be.above(0)",
                  "    pm.expect(data.userId).to.not.be.null",
                  "",
                  "    pm.environment.set(\"USER_TOKEN\", data.token)",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
