              "    pm.expect(json).to.have.property('message');\r",
              "    pm.expect(json).to.have.property('timestamp');\r",
              "});\r",
              "pm.test(\"Message content is correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.error).to.be.eq('FIELDS_ERROR');\r",
              "    pm.expect(json.message).to.be.oneOf([\r",
              "        'El país solo puede contener letras',\r",
              "        'Minimo cuatro caracteres y en inglés, Ej. Spain'\r",
              "    ])\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
