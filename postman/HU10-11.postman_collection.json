  "item": [
    {
      "name": "Get All Leagues",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('array');\r",
              "});\r",
              "pm.test(\"Each league has required properties\", function () {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    json.forEach(league => {\r",
              "        pm.expect(league).to.have.property('id');\r",
              "        pm.expect(league).to.have.property('name');\r",
              "        pm.expect(league).to.have.property('type');\r",
              "        pm.expect(league).to.have.property('country');\r",
              "        pm.expect(league).to.have.property('logo');\r",
              "        pm.expect(league).to.have.property('currentSeason');\r",
              "        pm.expect(league).to.have.property('startDate');\r",
              "        pm.expect(league).to.have.property('endDate');\r",
              "    });\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{LEAGUES_BASE_URL}}",
          "host": [
            "{{LEAGUES_BASE_URL}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get All Leagues Season Wrong",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {\r",
              "    pm.response.to.have.status(400);\r",
              "});\r",
              "pm.test(\"Error response structure\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('object');\r",
              "    pm.expect(json).to.have.property('error');\r",
              "    pm.expect(json).to.have.property('message');\r",
              "    pm.expect(json).to.have.property('timestamp');\r",
              "});\r",
              "pm.test(\"Message content is correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.message).to.eql(\"Sólo se puede las temporadas del 2022 al 2024\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
